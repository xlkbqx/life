function triGlyph(kind){
  // minimal alchemical-style glyphs as inline SVG strings
  if(kind==='up') return `<svg class="glyph" viewBox="0 0 26 26"><polygon points="13,4 23,21 3,21" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>`;
  if(kind==='down') return `<svg class="glyph" viewBox="0 0 26 26"><polygon points="13,22 3,5 23,5" fill="none" stroke="currentColor" stroke-width="1.6"/></svg>`;
  if(kind==='up-bar') return `<svg class="glyph" viewBox="0 0 26 26"><polygon points="13,4 23,21 3,21" fill="none" stroke="currentColor" stroke-width="1.6"/><line x1="7" y1="15" x2="19" y2="15" stroke="currentColor" stroke-width="1.6"/></svg>`;
  return `<svg class="glyph" viewBox="0 0 26 26"><polygon points="13,22 3,5 23,5" fill="none" stroke="currentColor" stroke-width="1.6"/><line x1="7" y1="11" x2="19" y2="11" stroke="currentColor" stroke-width="1.6"/></svg>`;
}

function phaseForDay(dayInCycle, cycleLength){
  const frac = dayInCycle / cycleLength;
  if(frac <= 0.18) return 'menstrual';
  if(frac <= 0.46) return 'folicular';
  if(frac <= 0.57) return 'ovulatoria';
  return 'lutea';
}

function diffInDays(a,b){
  const ms = b.setHours(0,0,0,0) - a.setHours(0,0,0,0);
  return Math.floor(ms / 86400000);
}

function getCycleInfo(config){
  const start = new Date(config.lastPeriodStart + 'T00:00:00');
  const today = new Date();
  let elapsed = diffInDays(new Date(start), new Date(today));
  if(elapsed < 0) elapsed = 0;
  const dayInCycle = (elapsed % config.cycleLength) + 1;
  const phaseKey = phaseForDay(dayInCycle, config.cycleLength);
  return { dayInCycle, cycleLength: config.cycleLength, phaseKey, fraction: dayInCycle / config.cycleLength };
}

