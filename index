async function renderWeeklyOverview(today){
  const container = document.getElementById('weeklyOverview');
  if(!container) return;

  const weekKey = getWeekKey(today);
  const weekData = await loadRitualWeek(weekKey);
  weekData.learningMinutes = weekData.learningMinutes || 0;
  const config = await loadRitualConfig();
  config.learningGoalHours = config.learningGoalHours || 3;
  const pos = getWeekPosition(today);
  const urgent = pos >= 5; // sábado o domingo
  const closing = pos === 4; // viernes, aviso suave

  document.getElementById('weeklyOverviewSub').textContent = urgent
    ? '¡Se acaba la semana! Esto es lo que todavía queda pendiente.'
    : 'Lo que no es diario pero igual hay que cumplir antes de que cierre la semana.';

  const laserDue = !config.laserLastDate || diffInDays(new Date(config.laserLastDate + 'T00:00:00'), new Date(today)) >= 4;

  container.innerHTML = `
    <div class="rit-item" id="weekNails"></div>
    <div class="rit-item" id="weekLaser"></div>
    <div class="rit-item" id="weekReading"></div>
    <div class="rit-item" id="weekLearning"></div>
    <div class="rit-item" id="weekMeditation"></div>
  `;

  function alertLine(done, name){
    if(done || !(urgent || closing)) return '';
    const msg = urgent ? `Se acaba la semana — ${name} sigue pendiente.` : `Ya casi termina la semana — no olvides ${name}.`;
    return `<div class="rit-item-desc" style="color:var(--menstrual); margin-top:6px;">⚠ ${msg}</div>`;
  }

  // Uñas
  const weekNails = document.getElementById('weekNails');
  weekNails.className = 'rit-item' + (weekData.nails ? ' done' : '');
  weekNails.innerHTML = `<label class="rit-row">
      <input type="checkbox" ${weekData.nails ? 'checked' : ''}>
      <div><div class="rit-item-name">Uñas</div><div class="rit-item-desc">Una vez por semana.</div></div>
    </label>
    ${alertLine(weekData.nails, 'hacerte las uñas')}`;
  weekNails.querySelector('input').onchange = async (e)=>{
    weekData.nails = e.target.checked;
    await saveRitualWeek(weekKey, weekData);
    renderWeeklyOverview(today);
  };

  // Láser
  const weekLaser = document.getElementById('weekLaser');
  weekLaser.className = 'rit-item' + (!laserDue ? ' done' : '');
  weekLaser.innerHTML = `
    <div class="rit-item-name">Láser</div>
    <div class="rit-item-desc">${laserDue ? 'Te toca hoy.' : 'Al día, cada 4 días aprox.'}</div>
    <div class="quick-add"><button class="qbtn" id="weekLaserBtn">Hecho hoy</button></div>
    ${alertLine(!laserDue, 'tu sesión de láser')}
  `;
  document.getElementById('weekLaserBtn').onclick = async ()=>{
    config.laserLastDate = todayStr();
    await saveRitualConfig(config);
    renderWeeklyOverview(today);
  };

  // Lectura
  const readingGoalMin = config.readingGoalHours * 60;
  const readingDone = weekData.readingMinutes >= readingGoalMin;
  const readingPct = Math.min(100, Math.round((weekData.readingMinutes / readingGoalMin) * 100));
  const weekReading = document.getElementById('weekReading');
  weekReading.className = 'rit-item' + (readingDone ? ' done' : '');
  weekReading.innerHTML = `
    <div class="rit-item-name">Lectura</div>
    <div class="progress-bar"><div class="progress-fill" style="width:${readingPct}%"></div></div>
    <div class="rit-item-desc">${(weekData.readingMinutes/60).toFixed(1)}h de ${config.readingGoalHours}h</div>
    <div class="quick-add">
      <button class="qbtn" data-min="15">+15 min</button>
      <button class="qbtn" data-min="30">+30 min</button>
      <button class="qbtn" data-min="60">+60 min</button>
    </div>
    ${alertLine(readingDone, 'tu meta de lectura')}
  `;
  weekReading.querySelectorAll('.qbtn').forEach(btn=>{
    btn.onclick = async ()=>{
      weekData.readingMinutes += parseInt(btn.dataset.min, 10);
      await saveRitualWeek(weekKey, weekData);
      renderWeeklyOverview(today);
    };
  });

  // Aprendizaje
  const learningGoalMin = config.learningGoalHours * 60;
  const learningDone = weekData.learningMinutes >= learningGoalMin;
  const learningPct = Math.min(100, Math.round((weekData.learningMinutes / learningGoalMin) * 100));
