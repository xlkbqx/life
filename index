      ${g.cost ? `<span class="gprice">$${g.cost.toLocaleString('es-CO')}</span>` : ''}`;
    li.querySelector('input').onchange = async (e)=>{
      groceryHave[g.name] = e.target.checked;
      await saveGroceryHave(groceryHave);
      renderNutricion();
    };
    groceryInventory.appendChild(li);
  });

  document.getElementById('groceryTotal').textContent = `Total estimado de pollo + salmón + verduras según filtro actual: $${total.toLocaleString('es-CO')}`;
}

// ---------- Ejercicio: render ----------
async function renderEjercicio(){
  const today = new Date();
  const dow = today.getDay();
  const config = await loadConfig();

  let phaseAlert = '';
  if(isValidConfig(config)){
    const info = getCycleInfo(config);
    if(info.phaseKey === 'menstrual'){
      phaseAlert = `
        <div class="phase-alert">
          <b>Estás en fase menstrual.</b> Baja todos los pesos un 30% aprox. y las series de fuerza a la mitad. Sube el cardio a 5 veces por semana, 30 minutos mínimo. Si el sangrado es abundante hoy, no entrenes fuerza — solo cardio suave si quieres, o descansa por completo.
        </div>`;
    }
  }

  const todayEx = WEEKDAY_EXERCISE[dow];
  let todayBody = '';
  if(todayEx.type === 'pesas'){
    todayBody = `
      <div class="ex-label">Pesas</div>
      <div class="ex-title">${GYM_DAY_GLUTEO.title}</div>
      <ul class="ex-list">${GYM_DAY_GLUTEO.items.map(i=>`<li>${i}</li>`).join('')}</ul>
    `;
  } else if(todayEx.items){
    todayBody = `
      <div class="ex-label">${todayEx.type === 'fijo' ? 'Día fijo' : 'Boost del día'}</div>
      <div class="ex-title">${todayEx.title}</div>
      <ul class="ex-list">${todayEx.items.map(i=>`<li>${i}</li>`).join('')}</ul>
      ${todayEx.why ? `<div class="prep-box"><b>Por qué:</b> ${todayEx.why}</div>` : ''}
    `;
  } else {
    todayBody = `
      <div class="ex-label">${todayEx.type === 'fijo' ? 'Día fijo' : 'Boost del día'}</div>
      <div class="ex-title">${todayEx.title}</div>
      <div class="rit-item-desc" style="margin-bottom:8px;">${todayEx.detail}</div>
      ${todayEx.why ? `<div class="prep-box"><b>Por qué:</b> ${todayEx.why}</div>` : ''}
    `;
  }

  app.innerHTML = `
    ${phaseAlert}
    <div class="today-exercise">${todayBody}</div>

    <div class="section-title">Tu semana</div>
    <div class="section-sub">Lunes y miércoles fijos, sábado siempre es glúteo, el resto son 20 min de pilates repartidos por grupo muscular en lo que el sábado no cubre.</div>
    <div id="weekExList"></div>
  `;

  const weekList = document.getElementById('weekExList');
  for(let i=1;i<=7;i++){
    const d = new Date(today);
    d.setDate(today.getDate() - dow + (i % 7)); // lunes(1)...domingo(0/7)
    const dayIndex = d.getDay();
    const ex = WEEKDAY_EXERCISE[dayIndex];
    const isToday = dayIndex === dow;
    const label = ex.type === 'pesas' ? GYM_DAY_GLUTEO.title : ex.title;
    const row = document.createElement('div');
    row.className = 'week-ex-row' + (isToday ? ' today-row' : '');
    row.innerHTML = `<span class="wd">${WEEKDAY_SHORT[dayIndex]}</span><span>${label}</span>`;
    weekList.appendChild(row);
  }
}

function buildDailyItem(item, dayData, dateKey){
  const checked = !!dayData[item.key];
  const el = document.createElement('div');
  el.className = 'rit-item' + (checked ? ' done' : '');
  el.innerHTML = `<label class="rit-row">
      <input type="checkbox" ${checked ? 'checked' : ''}>
      <div><div class="rit-item-name">${item.name}</div><div class="rit-item-desc">${item.desc}</div></div>
    </label>`;
  el.querySelector('input').onchange = async (e)=>{
    dayData[item.key] = e.target.checked;
    el.classList.toggle('done', e.target.checked);
    await saveRitualDay(dateKey, dayData);
  };
  return el;
}

