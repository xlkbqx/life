      ],
      fuego: [
        'Clase de baile o coreografía nueva que quieras aprender.',
        'Cardio moderado, algo que te haga sonreír.',
        'Prueba un movimiento o disciplina que nunca has intentado.'
      ],
      tierra: [
        'Organiza tu espacio o agenda para la semana que viene.',
        'Fuerza moderada en el gym, sin presión por superarte hoy.',
        'Planea una comida nutritiva nueva para probar.'
      ]
    }
  },
  ovulatoria: {
    label: 'Ovulatoria',
    sub: 'luna llena · brillo y expresión',
