    <div class="progress-bar"><div class="progress-fill" style="width:${learningPct}%"></div></div>
    <div class="rit-item-desc">${(weekData.learningMinutes/60).toFixed(1)}h de ${config.learningGoalHours}h</div>
    <div class="quick-add">
      <button class="qbtn" data-min="15">+15 min</button>
      <button class="qbtn" data-min="30">+30 min</button>
      <button class="qbtn" data-min="60">+60 min</button>
    </div>
    ${alertLine(learningDone, 'tu meta de aprendizaje')}
  `;
  weekLearning.querySelectorAll('.qbtn').forEach(btn=>{
    btn.onclick = async ()=>{
      weekData.learningMinutes += parseInt(btn.dataset.min, 10);
      await saveRitualWeek(weekKey, weekData);
      renderWeeklyOverview(today);
    };
  });

  // Meditación
  const meditationDone = (weekData.meditationCount || 0) >= 2;
