<!DOCTYPE html>
<html lang="es">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Mi OS · Daily</title>
<link rel="preconnect" href="https://fonts.googleapis.com">
<link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,300;0,9..144,500;0,9..144,600;1,9..144,500&family=Work+Sans:wght@300;400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
  :root{
    --bg: #1B1726;
    --surface: #241F33;
    --surface-2: #2C2640;
    --line: rgba(244,239,230,0.12);
    --text: #F4EFE6;
    --text-muted: #B8AFC4;
    --menstrual: #C1495B;
    --folicular: #6FA37A;
    --ovulatoria: #E3A857;
    --lutea: #B97A4A;
    --accent: var(--ovulatoria);
    --radius: 18px;
  }
  *{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  body{
    background: radial-gradient(ellipse 120% 80% at 50% -10%, #2B2440 0%, var(--bg) 55%);
    color: var(--text);
    font-family: 'Work Sans', sans-serif;
    min-height: 100vh;
    padding: 32px 18px 60px;
  }
  .wrap{max-width: 720px; margin: 0 auto;}

  .eyebrow{
    font-family: 'JetBrains Mono', monospace;
    font-size: 12px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin-bottom: 6px;
  }
  h1{
    font-family: 'Fraunces', serif;
    font-weight: 500;
    font-size: 34px;
    margin: 0 0 18px;
    letter-spacing: -0.01em;
  }
  .nav{
    display:flex;
    gap: 6px;
    border-bottom: 1px solid var(--line);
    margin-bottom: 28px;
    overflow-x:auto;
  }
  .nav button{
    background:none;
    border:none;
    color: var(--text-muted);
    font-family:'Work Sans', sans-serif;
    font-size: 14px;
    padding: 10px 14px;
    cursor: pointer;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
  }
  .nav button.active{
    color: var(--text);
    border-bottom: 2px solid var(--accent);
    font-weight: 500;
  }
  .nav button:disabled{
    cursor: default;
    opacity: 0.45;
  }

  /* ---- Setup card ---- */
  .card{
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 28px;
    margin-bottom: 20px;
  }
  .card h2{
    font-family:'Fraunces', serif;
    font-weight: 500;
    font-size: 20px;
    margin: 0 0 8px;
  }
  .card p.hint{
    color: var(--text-muted);
    font-size: 14px;
    margin: 0 0 20px;
    line-height: 1.5;
  }
  label{
    display:block;
    font-size: 13px;
    color: var(--text-muted);
    margin-bottom: 6px;
  }
  .field{margin-bottom: 18px;}
  input[type=date], input[type=number]{
    width: 100%;
    background: var(--surface-2);
    border: 1px solid var(--line);
    color: var(--text);
    padding: 11px 12px;
    border-radius: 10px;
    font-size: 15px;
    font-family: 'Work Sans', sans-serif;
  }
  input:focus{outline: 2px solid var(--accent); outline-offset: 1px;}
  .btn{
    background: var(--accent);
    color: #1B1726;
    border: none;
    padding: 12px 20px;
    border-radius: 10px;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    font-family: 'Work Sans', sans-serif;
  }
  .btn.ghost{
    background: transparent;
    border: 1px solid var(--line);
    color: var(--text);
    font-weight: 500;
  }
  .row{display:flex; gap: 12px; flex-wrap: wrap; align-items:center;}

  /* ---- Dial ---- */
  .dial-section{
    display:flex;
    flex-direction: column;
    align-items:center;
    text-align:center;
    margin-bottom: 30px;
  }
  .dial-wrap{position:relative; width: 230px; height: 230px;}
  .dial-center{
    position:absolute; inset:0;
    display:flex; flex-direction:column; align-items:center; justify-content:center;
  }
  .moon-glyph{font-size: 30px; line-height:1;}
  .day-number{
    font-family:'JetBrains Mono', monospace;
    font-size: 28px;
    margin-top: 4px;
  }
  .day-total{
    font-family:'JetBrains Mono', monospace;
    font-size: 13px;
    color: var(--text-muted);
  }
  .phase-name{
    font-family:'Fraunces', serif;
    font-size: 22px;
    margin-top: 14px;
  }
  .phase-energy{
    color: var(--text-muted);
    font-size: 14px;
    margin-top: 4px;
    max-width: 380px;
  }
  .settings-link{
    margin-top: 14px;
    font-size: 13px;
    color: var(--text-muted);
    background:none;
    border:none;
    text-decoration: underline;
    cursor:pointer;
    font-family:'Work Sans', sans-serif;
  }

  /* ---- Elements grid ---- */
  .section-title{
    font-family:'Fraunces', serif;
    font-size: 18px;
    font-weight: 500;
    margin: 0 0 4px;
  }
  .section-sub{
    color: var(--text-muted);
    font-size: 13px;
    margin: 0 0 18px;
  }
  .grid{
    display:grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 14px;
  }
  @media (max-width: 520px){ .grid{grid-template-columns: 1fr;} }

  .el-card{
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 20px;
    position: relative;
  }
  .el-head{
    display:flex;
    align-items:center;
    gap: 10px;
    margin-bottom: 12px;
  }
  .glyph{width: 26px; height: 26px; flex-shrink:0;}
  .el-name{
    font-family:'Fraunces', serif;
    font-size: 16px;
  }
  .el-sub{
    font-family:'JetBrains Mono', monospace;
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .el-activity{
    font-size: 14.5px;
    line-height: 1.5;
    margin-bottom: 14px;
  }
  .check-row{
    display:flex;
    align-items:center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
    cursor:pointer;
  }
  .check-row input{accent-color: var(--accent);}
  .el-card.done{ border-color: var(--el-color); }

  textarea{
    width:100%;
    background: var(--surface-2);
    border: 1px solid var(--line);
    color: var(--text);
    border-radius: 10px;
    padding: 10px 12px;
    font-family: 'Work Sans', sans-serif;
    font-size: 13.5px;
    resize: vertical;
    min-height: 64px;
    margin-top: 10px;
  }
  textarea:focus{outline: 2px solid var(--accent); outline-offset: 1px;}

  .toast{
    position: fixed;
    bottom: 24px;
    left: 50%;
    transform: translateX(-50%);
    background: var(--surface-2);
    border: 1px solid var(--line);
    color: var(--text);
    padding: 10px 18px;
    border-radius: 999px;
    font-size: 13px;
    opacity:0;
    transition: opacity 0.25s ease;
    pointer-events:none;
  }
  .toast.show{opacity:1;}

  .modal-overlay{
    position: fixed; inset:0;
    background: rgba(15,12,22,0.6);
    display:none;
    align-items:center;
    justify-content:center;
    padding: 20px;
    z-index: 10;
  }
  .modal-overlay.show{display:flex;}
  .modal{
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: var(--radius);
    padding: 26px;
    max-width: 380px;
    width: 100%;
  }

  .loading{ color: var(--text-muted); font-size: 14px; padding: 40px 0; text-align:center; }

  /* ---- Rituales ---- */
  .rit-block{ margin-bottom: 34px; }
  .rit-head{
    display:flex;
    align-items:baseline;
    gap: 10px;
    margin-bottom: 4px;
  }
  .rit-title{
    font-family:'Fraunces', serif;
    font-size: 20px;
  }
  .rit-tag{
