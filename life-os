    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
  }
  .rit-sub{ color: var(--text-muted); font-size: 13px; margin: 0 0 16px; }

  .rit-group-label{
    font-family:'JetBrains Mono', monospace;
    font-size: 11px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--text-muted);
    margin: 18px 0 10px;
  }
  .rit-group-label:first-child{ margin-top: 0; }

  .rit-item{
    background: var(--surface);
    border: 1px solid var(--line);
    border-radius: 14px;
    padding: 14px 16px;
    margin-bottom: 10px;
  }
  .rit-item.done{ border-color: var(--accent); }
  .rit-item.muted{ opacity: 0.5; }
  .rit-row{
    display:flex;
    align-items:flex-start;
    gap: 12px;
  }
  .rit-row input[type=checkbox]{
    margin-top: 2px;
    accent-color: var(--accent);
    width: 17px; height: 17px;
    flex-shrink:0;
  }
  .rit-item-name{ font-size: 14.5px; font-weight: 500; }
  .rit-item-desc{ font-size: 13px; color: var(--text-muted); margin-top: 3px; line-height: 1.45; }

  .week-strip{
    display:grid;
    grid-template-columns: repeat(7, 1fr);
    gap: 6px;
    margin-top: 12px;
  }
  .week-day{
    background: var(--surface-2);
    border: 1px solid var(--line);
    border-radius: 10px;
    padding: 8px 4px;
    text-align:center;
  }
  .week-day.today{ border-color: var(--accent); }
  .week-day .wd-label{
    font-family:'JetBrains Mono', monospace;
    font-size: 10px;
    color: var(--text-muted);
    text-transform: uppercase;
  }
  .week-day .wd-task{ font-size: 10.5px; margin-top: 4px; line-height: 1.3; min-height: 26px; }

  .progress-bar{
    background: var(--surface-2);
    border-radius: 999px;
    height: 8px;
    overflow:hidden;
    margin: 10px 0 8px;
  }
  .progress-fill{
    height:100%;
    background: var(--accent);
    border-radius: 999px;
  }
  .quick-add{ display:flex; gap: 8px; flex-wrap:wrap; margin-top: 10px; }
  .qbtn{
    background: var(--surface-2);
    border: 1px solid var(--line);
    color: var(--text);
    padding: 7px 12px;
    border-radius: 999px;
    font-size: 12.5px;
    cursor:pointer;
    font-family:'Work Sans', sans-serif;
  }
  .qbtn:hover{ border-color: var(--accent); }
  .goal-edit{
    font-size: 12px;
    color: var(--text-muted);
    background:none;
    border:none;
    text-decoration: underline;
    cursor:pointer;
    margin-left: 6px;
    font-family:'Work Sans', sans-serif;
  }
</style>
</head>
