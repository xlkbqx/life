  2: { label: 'Cepillado', desc: 'Cepilla bien el cabello en la mañana.' },
  3: { label: 'Cuidado normal', desc: 'Rutina habitual, sin lavado.' },
  4: { label: 'Lavado', desc: 'Día de lavado de cabello.' },
  5: { label: 'Cuidado normal', desc: 'Rutina habitual, sin lavado.' },
  6: { label: 'Lavado', desc: 'Día de lavado de cabello.' }
};
const WEEKDAY_SHORT = ['Dom','Lun','Mar','Mié','Jue','Vie','Sáb'];

function getWeekKey(date){
  const d = new Date(date);
  const dow = (d.getDay() + 6) % 7; // 0 = lunes
  d.setDate(d.getDate() - dow);
  return d.toISOString().slice(0,10);
}
function nextMonday(date){
  const d = new Date(date);
  const dow = d.getDay();
  const add = dow === 1 ? 7 : ((8 - dow) % 7 || 7);
  d.setDate(d.getDate() + add);
  return d;
}
function fmtShort(d){
  return d.toLocaleDateString('es-CO', {day:'numeric', month:'short'});
}

async function loadRitualDay(dateKey){
  try{
    const r = await window.storage.get('ritual-day:' + dateKey);
    return r ? JSON.parse(r.value) : {};
  }catch(e){ return {}; }
}
async function saveRitualDay(dateKey, data){
  try{ await window.storage.set('ritual-day:' + dateKey, JSON.stringify(data)); }
  catch(e){ showToast('No se pudo guardar.'); }
}
async function loadRitualWeek(weekKey){
  try{
    const r = await window.storage.get('ritual-week:' + weekKey);
    return r ? JSON.parse(r.value) : { nails:false, readingMinutes:0, meditationCount:0 };
  }catch(e){ return { nails:false, readingMinutes:0, meditationCount:0 }; }
}
async function saveRitualWeek(weekKey, data){
  try{ await window.storage.set('ritual-week:' + weekKey, JSON.stringify(data)); }
  catch(e){ showToast('No se pudo guardar tu semana.'); }
}
async function loadRitualConfig(){
  try{
    const r = await window.storage.get('ritual-config');
    return r ? JSON.parse(r.value) : { readingGoalHours: 3, laserLastDate: null };
  }catch(e){ return { readingGoalHours: 3, laserLastDate: null }; }
}
async function saveRitualConfig(cfg){
  try{ await window.storage.set('ritual-config', JSON.stringify(cfg)); }
  catch(e){ showToast('No se pudo guardar.'); }
}

// ---------- Rendering ----------
function renderSetup(){
  app.innerHTML = `
    <div class="card">
      <h2>Sincronicemos tu Daily con tu ciclo</h2>
      <p class="hint">Cuéntame cuándo empezó tu último periodo y qué tan largo es tu ciclo en promedio. Con eso calculo en qué fase estás hoy y equilibro tus 4 elementos según tu energía disponible.</p>
      <div class="field">
        <label for="startInput">Inicio de tu último periodo</label>
        <input type="date" id="startInput" value="${todayStr()}">
      </div>
      <div class="field">
        <label for="lengthInput">Duración promedio de tu ciclo (días)</label>
        <input type="number" id="lengthInput" min="20" max="45" value="28">
      </div>
      <button class="btn" id="setupBtn">Calcular mi día</button>
    </div>
  `;
  document.getElementById('setupBtn').onclick = async ()=>{
    const start = document.getElementById('startInput').value;
    const length = parseInt(document.getElementById('lengthInput').value || '28', 10);
