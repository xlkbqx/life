async function renderDashboard(){
  const config = await loadConfig();
  if(!config){ renderSetup(); return; }

  const info = getCycleInfo(config);
  const phase = PHASES[info.phaseKey];
  const dateKey = todayStr();
  const dayData = await loadDay(dateKey);

  const angle = info.fraction * 360 - 90;
  const r = 95;
  const cx = 115, cy = 115;
  const mx = cx + r * Math.cos(angle * Math.PI/180);
  const my = cy + r * Math.sin(angle * Math.PI/180);

  const arcs = arcSegments(cx, cy, r);

  app.innerHTML = `
    <div class="dial-section">
      <div class="dial-wrap">
        <svg viewBox="0 0 230 230" width="230" height="230">
          ${arcs}
          <circle cx="${cx}" cy="${cy}" r="${r}" fill="none" stroke="var(--line)" stroke-width="1"/>
          <circle cx="${mx.toFixed(1)}" cy="${my.toFixed(1)}" r="6" fill="${phase.color}" stroke="var(--bg)" stroke-width="2"/>
        </svg>
        <div class="dial-center">
          <div class="moon-glyph">${phase.glyph}</div>
          <div class="day-number" style="color:${phase.color}">${info.dayInCycle}</div>
          <div class="day-total">de ${info.cycleLength} días</div>
        </div>
      </div>
      <div class="phase-name">Fase ${phase.label}</div>
      <div class="phase-energy">${phase.energy}</div>
      <button class="settings-link" id="openSettings">Ajustar fecha de mi periodo</button>
    </div>

    <div class="section-title">Hoy equilibras tus 4 elementos</div>
    <div class="section-sub">${phase.sub}</div>
    <div class="grid" id="elGrid"></div>
  `;

  const grid = document.getElementById('elGrid');
  ELEMENTS.forEach(el=>{
    const pool = phase.pools[el.key];
    const activity = pool[info.dayInCycle % pool.length];
    const checked = !!dayData.checks[el.key];
    const card = document.createElement('div');
    card.className = 'el-card' + (checked ? ' done' : '');
    card.style.setProperty('--el-color', phase.color);
    card.innerHTML = `
      <div class="el-head" style="color:${phase.color}">
        ${el.glyph}
        <div>
          <div class="el-name" style="color:var(--text)">${el.name}</div>
          <div class="el-sub">${el.sub}</div>
        </div>
      </div>
      <div class="el-activity">${activity}</div>
      <label class="check-row">
        <input type="checkbox" ${checked ? 'checked' : ''} data-el="${el.key}">
        Hecho hoy
      </label>
      ${el.key === 'agua' ? `<textarea placeholder="Escribe aquí tu journaling de hoy…">${escapeHtml(dayData.journal || '')}</textarea>` : ''}
    `;
    grid.appendChild(card);

    const checkbox = card.querySelector('input[type=checkbox]');
    checkbox.onchange = async ()=>{
      dayData.checks[el.key] = checkbox.checked;
      card.classList.toggle('done', checkbox.checked);
      await saveDay(dateKey, dayData);
    };

    if(el.key === 'agua'){
      const ta = card.querySelector('textarea');
      let debounce;
      ta.oninput = ()=>{
        clearTimeout(debounce);
        debounce = setTimeout(async ()=>{
          dayData.journal = ta.value;
          await saveDay(dateKey, dayData);
        }, 600);
      };
    }
  });

  document.getElementById('openSettings').onclick = ()=> openSettingsModal(config);
}

function arcSegments(cx, cy, r){
  // four quadrant arcs colored by phase, starting at top, clockwise
  const bounds = [0, 0.18, 0.46, 0.57, 1];
  const keys = ['menstrual','folicular','ovulatoria','lutea'];
  let svg = '';
  for(let i=0;i<4;i++){
    const a0 = bounds[i]*360 - 90;
    const a1 = bounds[i+1]*360 - 90;
    svg += describeArc(cx, cy, r, a0, a1, PHASES[keys[i]].color);
  }
  return svg;
}
function describeArc(cx, cy, r, a0, a1, color){
  const start = polarToCartesian(cx, cy, r, a1);
  const end = polarToCartesian(cx, cy, r, a0);
  const largeArc = (a1 - a0) <= 180 ? 0 : 1;
  return `<path d="M ${start.x} ${start.y} A ${r} ${r} 0 ${largeArc} 0 ${end.x} ${end.y}" fill="none" stroke="${color}" stroke-width="7" stroke-linecap="round" opacity="0.85"/>`;
}
function polarToCartesian(cx, cy, r, angleDeg){
  const a = angleDeg * Math.PI / 180;
  return { x: (cx + r*Math.cos(a)).toFixed(1), y: (cy + r*Math.sin(a)).toFixed(1) };
}
function escapeHtml(s){
  return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
}

function openSettingsModal(config){
  const overlay = document.getElementById('settingsOverlay');
  document.getElementById('editStart').value = config.lastPeriodStart;
  document.getElementById('editLength').value = config.cycleLength;
  overlay.classList.add('show');

  document.getElementById('cancelSettings').onclick = ()=> overlay.classList.remove('show');
  document.getElementById('saveSettings').onclick = async ()=>{
    const start = document.getElementById('editStart').value;
    const length = parseInt(document.getElementById('editLength').value || '28', 10);
    if(!start){ showToast('Necesito una fecha.'); return; }
    await saveConfig({lastPeriodStart: start, cycleLength: length});
    overlay.classList.remove('show');
    showToast('Ciclo actualizado.');
    renderDashboard();
  };
}

// ---------- Rituales: render ----------
async function renderRituales(){
  const today = new Date();
  const dateKey = todayStr();
  const weekKey = getWeekKey(today);
  const isMonday = today.getDay() === 1;

  const dayData = await loadRitualDay(dateKey);
  const weekData = await loadRitualWeek(weekKey);
  const config = await loadRitualConfig();

  const hairToday = HAIR_SCHEDULE[today.getDay()];
  const laserDue = !config.laserLastDate || diffInDays(new Date(config.laserLastDate + 'T00:00:00'), new Date(today)) >= 4;
  const laserNextInfo = config.laserLastDate
    ? (laserDue ? 'Te toca hoy.' : `Próxima sesión en ${4 - diffInDays(new Date(config.laserLastDate + 'T00:00:00'), new Date(today))} día(s).`)
    : 'Aún no registras tu primera sesión.';

  app.innerHTML = `
    <div class="rit-block">
      <div class="rit-head"><span class="rit-title">Body</span><span class="rit-tag">cuerpo</span></div>
      <p class="rit-sub">Skincare, hair care y cuidado físico diario.</p>

      <div class="rit-group-label">Hoy</div>
      <div id="bodyDaily"></div>

      <div class="rit-group-label">Hair care · esta semana</div>
      <div class="rit-item">
        <div class="rit-item-name">${hairToday.label}</div>
        <div class="rit-item-desc">${hairToday.desc}</div>
        <div class="week-strip" id="hairStrip"></div>
      </div>

      <div class="rit-group-label">Movimiento · esta semana</div>
      <div class="rit-item" id="movToday"></div>
      <div class="week-strip" id="movStrip"></div>

      <div class="rit-group-label">Semanal</div>
      <div id="bodyWeekly"></div>
    </div>

    <div class="rit-block">
      <div class="rit-head"><span class="rit-title">Mind</span><span class="rit-tag">mente</span></div>
      <p class="rit-sub">Aprendizaje diario y lectura semanal.</p>

      <div class="rit-group-label">Hoy</div>
      <div id="mindDaily"></div>

      <div class="rit-group-label">Semanal</div>
      <div class="rit-item" id="readingItem"></div>
    </div>

    <div class="rit-block">
      <div class="rit-head"><span class="rit-title">Soul</span><span class="rit-tag">alma</span></div>
      <p class="rit-sub">El resto de tu práctica espiritual vive en Daily — aquí solo tu meditación semanal.</p>

      <div class="rit-group-label">Semanal</div>
      <div class="rit-item" id="meditationItem"></div>
    </div>
  `;

  // ---- Body daily ----
  const bodyDaily = document.getElementById('bodyDaily');
  const bodyItems = [
    {key:'skincareAM', name:'Skincare AM', desc:'Limpiador suave + hidratante + protector solar.'},
    {key:'skincarePM', name:'Skincare PM', desc:'Limpiador suave + tratamiento + hidratante reparadora.'},
    {key:'sunscreen', name:'Protector solar', desc:'Esencial mientras tomas isotretinoína: reaplica si sales varias horas.'},
    {key:'hair', name:`Hair care de hoy: ${hairToday.label}`, desc:hairToday.desc}
  ];
  bodyItems.forEach(item => bodyDaily.appendChild(buildDailyItem(item, dayData, dateKey)));

  // Isotretinoína — solo lunes
  const isoItem = document.createElement('div');
  isoItem.className = 'rit-item' + (isMonday ? '' : ' muted') + (dayData.isotretinoina ? ' done' : '');
  isoItem.innerHTML = isMonday
    ? `<label class="rit-row">
         <input type="checkbox" id="iso-check" ${dayData.isotretinoina ? 'checked' : ''}>
         <div><div class="rit-item-name">Isotretinoína</div><div class="rit-item-desc">Hoy es lunes: toma tu dosis.</div></div>
       </label>`
    : `<div class="rit-row"><div><div class="rit-item-name">Isotretinoína</div><div class="rit-item-desc">Toca cada lunes. Próxima toma: ${fmtShort(nextMonday(today))}.</div></div></div>`;
  bodyDaily.appendChild(isoItem);
  if(isMonday){
    document.getElementById('iso-check').onchange = async (e)=>{
      dayData.isotretinoina = e.target.checked;
      isoItem.classList.toggle('done', e.target.checked);
      await saveRitualDay(dateKey, dayData);
    };
  }

  // hair week strip
  const hairStrip = document.getElementById('hairStrip');
  for(let i=0;i<7;i++){
    const d = new Date(); d.setDate(d.getDate() - ((d.getDay()+6)%7) + i);
    const isToday = d.toDateString() === today.toDateString();
    const sched = HAIR_SCHEDULE[d.getDay()];
    const cell = document.createElement('div');
    cell.className = 'week-day' + (isToday ? ' today' : '');
    cell.innerHTML = `<div class="wd-label">${WEEKDAY_SHORT[d.getDay()]}</div><div class="wd-task">${sched.label}</div>`;
    hairStrip.appendChild(cell);
  }

  // ---- Body weekly ----
  const bodyWeekly = document.getElementById('bodyWeekly');

  const nailsItem = document.createElement('div');
  nailsItem.className = 'rit-item' + (weekData.nails ? ' done' : '');
  nailsItem.innerHTML = `<label class="rit-row">
      <input type="checkbox" id="nails-check" ${weekData.nails ? 'checked' : ''}>
      <div><div class="rit-item-name">Uñas</div><div class="rit-item-desc">Una vez por semana.</div></div>
    </label>`;
  bodyWeekly.appendChild(nailsItem);
  document.getElementById('nails-check').onchange = async (e)=>{
    weekData.nails = e.target.checked;
    nailsItem.classList.toggle('done', e.target.checked);
    await saveRitualWeek(weekKey, weekData);
  };

  const laserItem = document.createElement('div');
  laserItem.className = 'rit-item' + (!laserDue ? ' done' : '');
  laserItem.innerHTML = `
    <div class="rit-item-name">Láser</div>
    <div class="rit-item-desc">Cada 4 días, aprox. dos veces por semana. ${laserNextInfo}</div>
    <div class="quick-add">
      <button class="qbtn" id="laser-done">Hecho hoy</button>
    </div>`;
  bodyWeekly.appendChild(laserItem);
  document.getElementById('laser-done').onclick = async ()=>{
    config.laserLastDate = dateKey;
    await saveRitualConfig(config);
    showToast('Sesión de láser registrada.');
    renderRituales();
  };

  // ---- Mind daily ----
  const mindDaily = document.getElementById('mindDaily');
  mindDaily.appendChild(buildDailyItem({key:'learning', name:'Aprendizaje (mín. 1 hora)', desc:'Dedica al menos 60 minutos a aprender algo nuevo hoy.'}, dayData, dateKey));

  // ---- Reading (weekly, time-based) ----
  const goalMinutes = config.readingGoalHours * 60;
  const pct = Math.min(100, Math.round((weekData.readingMinutes / goalMinutes) * 100));
  const readingItem = document.getElementById('readingItem');
  readingItem.innerHTML = `
    <div class="rit-item-name">Lectura
      <button class="goal-edit" id="editGoal">cambiar meta</button>
    </div>
    <div class="rit-item-desc">Meta: ${config.readingGoalHours}h esta semana</div>
    <div class="progress-bar"><div class="progress-fill" style="width:${pct}%"></div></div>
    <div class="rit-item-desc">${(weekData.readingMinutes/60).toFixed(1)}h de ${config.readingGoalHours}h</div>
    <div class="quick-add">
      <button class="qbtn" data-min="15">+15 min</button>
      <button class="qbtn" data-min="30">+30 min</button>
      <button class="qbtn" data-min="60">+60 min</button>
    </div>
  `;
  readingItem.querySelectorAll('.qbtn').forEach(btn=>{
    btn.onclick = async ()=>{
      weekData.readingMinutes += parseInt(btn.dataset.min, 10);
      await saveRitualWeek(weekKey, weekData);
      renderRituales();
    };
  });
  document.getElementById('editGoal').onclick = async ()=>{
    const val = prompt('¿Cuántas horas a la semana quieres leer?', config.readingGoalHours);
    if(val && !isNaN(parseFloat(val))){
      config.readingGoalHours = parseFloat(val);
      await saveRitualConfig(config);
      renderRituales();
    }
  };

  // ---- Meditation (weekly, 2x target) ----
  const meditationItem = document.getElementById('meditationItem');
  meditationItem.innerHTML = `
    <div class="rit-item-name">Meditación</div>
    <div class="rit-item-desc">${weekData.meditationCount} de 2 sesiones esta semana</div>
    <div class="quick-add">
      <button class="qbtn" id="med-add">+1 sesión</button>
      ${weekData.meditationCount > 0 ? '<button class="qbtn" id="med-remove">-1</button>' : ''}
    </div>
  `;
  document.getElementById('med-add').onclick = async ()=>{
    weekData.meditationCount += 1;
    await saveRitualWeek(weekKey, weekData);
    renderRituales();
  };
  const medRemove = document.getElementById('med-remove');
  if(medRemove) medRemove.onclick = async ()=>{
    weekData.meditationCount = Math.max(0, weekData.meditationCount - 1);
    await saveRitualWeek(weekKey, weekData);
    renderRituales();
  };
}

function buildDailyItem(item, dayData, dateKey){
  const checked = !!dayData[item.key];
  const el = document.createElement('div');
  el.className = 'rit-item' + (checked ? ' done' : '');
  el.innerHTML = `<label class="rit-row">
      <input type="checkbox" ${checked ? 'checked' : ''}>
      <div><div class="rit-item-name">${item.name}</div><div class="rit-item-desc">${item.desc}</div></div>
    </label>`;
  el.querySelector('input').onchange = async (e)=>{
    dayData[item.key] = e.target.checked;
    el.classList.toggle('done', e.target.checked);
    await saveRitualDay(dateKey, dayData);
  };
  return el;
}

// ---------- Tabs ----------
function setActiveTab(id){
  document.querySelectorAll('.nav button').forEach(b => b.classList.remove('active'));
  const btn = document.getElementById(id);
  if(btn) btn.classList.add('active');
}

document.getElementById('tab-daily').onclick = ()=>{ setActiveTab('tab-daily'); renderDashboard(); };
document.getElementById('tab-rituales').onclick = ()=>{ setActiveTab('tab-rituales'); renderRituales(); };

renderDashboard();

</script>
